#!/usr/bin/env bash
# decide — auto bench-and-decide for an M4-tuned candidate kernel vs current M2 flat.
#
#   ./decide <kernel> <candidate.metal>
#
# Bench current src/ version on M2, swap in candidate, bench again.
# - If candidate is broken on M2 → split into <name>/{default,m4}.metal.
# - If candidate is slower on M2 by >5% → split the same way.
# - If candidate matches or beats M2 → flat replace.
# Prints the decision and updates the repo accordingly.
set -uo pipefail
cd "$(dirname "$0")"

[ $# -ne 2 ] && { echo "usage: ./decide <kernel> <candidate.metal>" >&2; exit 64; }
NAME="$1"
CAND="$2"
[ ! -f "$CAND" ] && { echo "[decide] candidate file not found: $CAND" >&2; exit 1; }

# Find set
SET=""
for s in common standard full; do
    if [ -f "src/kernels/$s/$NAME.metal" ] || [ -d "src/kernels/$s/$NAME" ]; then
        SET="$s"; break
    fi
done
[ -z "$SET" ] && { echo "[decide] no such kernel: $NAME" >&2; exit 1; }

# Detect kind: flat .metal or dir
FLAT="src/kernels/$SET/$NAME.metal"
DIR="src/kernels/$SET/$NAME"

if [ -f "$FLAT" ]; then
    KIND="flat"; CURRENT_FILE="$FLAT"
elif [ -d "$DIR" ]; then
    KIND="dir"; CURRENT_FILE="$DIR/default.metal"
    [ ! -f "$CURRENT_FILE" ] && { echo "[decide] dir form but no default.metal" >&2; exit 1; }
else
    echo "[decide] kernel files missing" >&2; exit 1
fi

echo "[decide] kernel=$NAME set=$SET kind=$KIND"

# Bench current
echo "[decide] benching current on M2..."
out=$(SKIP_BUILD=1 ./bench "$NAME" --no-save -- --iters 50 2>&1)
CUR_OK=$(echo "$out" | grep -c "correctness : ✓ correct")
CUR_SP=$(echo "$out" | awk '/^  speedup/ { gsub(/×/,"",$3); print $3; exit }')
echo "  current: speedup=$CUR_SP correct=$CUR_OK"
[ "$CUR_OK" -eq 0 ] && { echo "[decide] current kernel broken on M2; aborting" >&2; exit 2; }

# Swap in candidate
BACKUP=$(mktemp)
cp "$CURRENT_FILE" "$BACKUP"
cp "$CAND" "$CURRENT_FILE"
make --silent all >/dev/null 2>&1 || { echo "[decide] build failed with candidate; reverting"; cp "$BACKUP" "$CURRENT_FILE"; rm "$BACKUP"; exit 3; }

out=$(SKIP_BUILD=1 ./bench "$NAME" --no-save -- --iters 50 2>&1)
CAND_OK=$(echo "$out" | grep -c "correctness : ✓ correct")
CAND_SP=$(echo "$out" | awk '/^  speedup/ { gsub(/×/,"",$3); print $3; exit }')
echo "  candidate: speedup=$CAND_SP correct=$CAND_OK"

# Decision
DECISION=""
if [ "$CAND_OK" -eq 0 ]; then
    DECISION="SPLIT (candidate broken on M2)"
elif python3 -c "import sys; sys.exit(0 if float('$CAND_SP') >= float('$CUR_SP') * 0.95 else 1)"; then
    DECISION="FLAT REPLACE"
else
    DECISION="SPLIT (candidate slower on M2)"
fi

case "$DECISION" in
    "FLAT REPLACE")
        echo "[decide] $DECISION ($CUR_SP → $CAND_SP)"
        # leave candidate in place; remove dir if it existed only for m4
        ;;
    SPLIT*)
        echo "[decide] $DECISION — restoring default, adding m4 variant"
        # restore default
        cp "$BACKUP" "$CURRENT_FILE"
        # promote to dir if needed
        if [ "$KIND" = "flat" ]; then
            mkdir -p "$DIR"
            mv "$FLAT" "$DIR/default.metal"
        fi
        cp "$CAND" "$DIR/m4.metal"
        ;;
esac
rm "$BACKUP"
make --silent all >/dev/null 2>&1
echo "[decide] DONE $NAME: $DECISION"
