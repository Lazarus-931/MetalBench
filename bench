#!/usr/bin/env bash
# bench <name>            — build, run, save to results/<chip>/<name>.json
# bench <name> --no-save  — skip the save
# bench <name> -- --target compute --iters 200
#                         — pass extra args through to harness.py
set -euo pipefail
cd "$(dirname "$0")"

if [ $# -lt 1 ]; then
  echo "usage: ./bench <name> [--no-save] [-- <harness args>]" >&2
  exit 64
fi

name="$1"; shift
save="--save"
extra=()

while [ $# -gt 0 ]; do
  case "$1" in
    --no-save) save=""; shift ;;
    --) shift; extra=("$@"); break ;;
    *)  extra+=("$1"); shift ;;
  esac
done

make --silent all 1>&2
if [ -n "$save" ]; then
  echo "[bench] running '$name' (save=on)" >&2
else
  echo "[bench] running '$name' (save=off)" >&2
fi
exec python3 src/mlx_scripts/harness.py "$name" ${save:-} "${extra[@]+"${extra[@]}"}"
