#!/usr/bin/env bash
# bench — one-command MetalBench runner.
#
#   ./bench <name>            # build (if needed) + run + save to results/<chip>/<name>.json
#   ./bench <name> --no-save  # don't write the result file
#   ./bench <name> -- --capture out.gputrace
#                             # extra args after `--` pass through to harness.py
#
# Defaults: warmup=10 iters=100 (set in harness.py).
set -euo pipefail

repo_root="$(cd "$(dirname "$0")" && pwd)"
cd "$repo_root"

if [ $# -lt 1 ]; then
  echo "usage: ./bench <name> [--no-save] [-- <harness args>]" >&2
  echo "       e.g. ./bench sqr_matmul" >&2
  exit 64
fi

name="$1"; shift
save_flag="--save"
passthrough=()

while [ $# -gt 0 ]; do
  case "$1" in
    --no-save) save_flag=""; shift ;;
    --) shift; passthrough=("$@"); break ;;
    *)  passthrough+=("$1"); shift ;;
  esac
done

# Build only if something has changed.
make --silent all 1>&2

echo "[bench] running '$name' (warmup=10, iters=100, save=${save_flag:+on}${save_flag:-off})" >&2
exec python3 src/mlx_scripts/harness.py "$name" $save_flag "${passthrough[@]}"
