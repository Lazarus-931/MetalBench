#!/usr/bin/env bash
# verify — reviewer-side. Re-run a PR's claimed numbers on your own hardware.
#
# Usage:
#   ./verify 47                      # PR number on origin
#   ./verify user/MetalBench:branch  # explicit fork:branch
#
# Behavior:
#   1. Checks out the PR into /tmp/mb-verify-<pr>
#   2. Diffs the PR vs main, finds changed .metal files
#   3. For each changed kernel: bench in the PR worktree (3× median)
#   4. Reads PR's results/<chip>/results.md for claimed numbers (your chip only)
#   5. Compares: PASS if measured ∈ claimed × [0.85, 1.15] and correctness ✓
#   6. Prints a copy-pasteable comment block for the PR thread.
set -uo pipefail
cd "$(dirname "$0")"

if [ $# -ne 1 ]; then
  echo "usage: ./verify <pr-number> | <fork:branch>" >&2
  exit 64
fi

TARGET="$1"
WORKTREE="/tmp/mb-verify-${TARGET//[\/:]/_}"

# 1. Materialize the PR --------------------------------------------------------
rm -rf "$WORKTREE"
if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
  command -v gh >/dev/null || { echo "[verify] needs 'gh' (gh cli)" >&2; exit 1; }
  echo "[verify] fetching PR #$TARGET ..." >&2
  gh pr checkout "$TARGET" --recurse-submodules=false 2>/dev/null \
    || { echo "[verify] gh pr checkout failed" >&2; exit 1; }
  PR_BRANCH=$(git branch --show-current)
  git checkout main 2>/dev/null
  git worktree add "$WORKTREE" "$PR_BRANCH" 2>&1 | tail -2
else
  fork="${TARGET%%:*}"; branch="${TARGET##*:}"
  echo "[verify] cloning $fork@$branch ..." >&2
  git fetch "git@github.com:${fork}.git" "$branch:verify_${branch//\//_}" 2>&1 | tail -2
  git worktree add "$WORKTREE" "verify_${branch//\//_}" 2>&1 | tail -2
fi

# 2. Find changed kernels ------------------------------------------------------
cd "$WORKTREE"
CHANGED=$(git diff --name-only main -- 'metal/kernels/**/*.metal' 2>/dev/null)
if [ -z "$CHANGED" ]; then
  echo "[verify] no kernel changes in this PR" >&2
  cd - >/dev/null
  exit 0
fi

# Map .metal paths → kernel name (handling directory variants)
KERNELS=()
for f in $CHANGED; do
  base=$(basename "$f" .metal)
  parent=$(basename "$(dirname "$f")")
  if [ "$parent" = "common" ] || [ "$parent" = "standard" ] || [ "$parent" = "full" ]; then
    KERNELS+=("$base")
  else
    KERNELS+=("$parent")
  fi
done
KERNELS=($(printf '%s\n' "${KERNELS[@]}" | awk '!seen[$0]++'))
echo "[verify] kernels changed: ${KERNELS[*]}" >&2

# 3. Determine chip + read PR's claims ----------------------------------------
CHIP=$(python3 -c "import sys; sys.path.insert(0,'mlx/scripts'); import mlx_helpers as H; print(H.bucket_key())")
PR_RESULTS="$WORKTREE/results/${CHIP}/results.md"
if [ ! -f "$PR_RESULTS" ]; then
  echo "[verify] WARN: PR has no results/${CHIP}/results.md — claims unverifiable on this chip" >&2
  HAS_CLAIMS=0
else
  HAS_CLAIMS=1
fi

claim_for() {
  local name="$1"
  [ "$HAS_CLAIMS" = "0" ] && { echo "—|—"; return; }
  awk -F'\\|' -v k="$name" '
    /^\| / {
      gsub(/^ +| +$/, "", $2);
      if ($2 == k) {
        ms=$3;  gsub(/^ +| +$/, "", ms);
        sp=$4;  gsub(/^ +| +×|×$/, "", sp); gsub(/×/, "", sp);
        gsub(/^ +| +$/, "", sp);
        print ms "|" sp; exit
      }
    }' "$PR_RESULTS"
}

# 4. Bench each kernel in the PR worktree -------------------------------------
PASS=0; FAIL=0; SKIP=0
declare -a REPORT_ROWS=()

for name in "${KERNELS[@]}"; do
  echo "" >&2
  echo "[verify] benching $name (3 runs) ..." >&2
  declare -a runs=()
  ok=1
  for i in 1 2 3; do
    out=$(./bench "$name" --no-save 2>&1) || ok=0
    if ! echo "$out" | grep -q "correctness : ✓ correct"; then ok=0; fi
    ms=$(echo "$out" | awk '/^  kernel  / { gsub(/ms/,"",$3); print $3; exit }')
    sp=$(echo "$out" | awk '/^  speedup/  { gsub(/×/,"",$3); print $3; exit }')
    runs+=("$ms $sp")
  done

  if [ "$ok" -ne 1 ]; then
    REPORT_ROWS+=("| $name | — | — | — | — | ❌ correctness FAIL |")
    FAIL=$((FAIL+1)); continue
  fi

  # Median by ms
  median_ms=$(printf '%s\n' "${runs[@]}" | awk '{print $1}' | sort -n | awk 'NR==2')
  median_sp=$(printf '%s\n' "${runs[@]}" | awk '{print $2}' | sort -n | awk 'NR==2')
  claim=$(claim_for "$name")
  claim_ms="${claim%%|*}"
  claim_sp="${claim##*|}"

  if [ "$claim_ms" = "—" ] || [ -z "$claim_ms" ]; then
    REPORT_ROWS+=("| $name | $claim_ms | $median_ms | $claim_sp | ${median_sp}× | ⚠️  no claim |")
    SKIP=$((SKIP+1)); continue
  fi

  # ±15% tolerance on time
  status=$(python3 -c "
c=float('$claim_ms'); m=float('$median_ms')
print('PASS' if 0.85*c <= m <= 1.15*c else 'FAIL')")
  if [ "$status" = "PASS" ]; then
    REPORT_ROWS+=("| $name | ${claim_ms}ms | ${median_ms}ms | ${claim_sp}× | ${median_sp}× | ✅ VERIFIED |")
    PASS=$((PASS+1))
  else
    REPORT_ROWS+=("| $name | ${claim_ms}ms | ${median_ms}ms | ${claim_sp}× | ${median_sp}× | ❌ off >15% |")
    FAIL=$((FAIL+1))
  fi
done

cd - >/dev/null

# 5. Output --------------------------------------------------------------------
echo ""
echo "──────────────────────────────────────────────────────────────"
echo "  VERIFY  PR=$TARGET  chip=$CHIP  pass=$PASS fail=$FAIL skip=$SKIP"
echo "──────────────────────────────────────────────────────────────"
echo ""
echo "| kernel | claimed (ms) | measured (ms) | claimed × | measured × | status |"
echo "|---|---|---|---|---|---|"
printf '%s\n' "${REPORT_ROWS[@]}"
echo ""
echo "Tolerance: ±15% on median of 3 runs."
echo "Reviewer chip: \`$CHIP\` — other chips not verified."
echo "──────────────────────────────────────────────────────────────"

[ "$FAIL" -eq 0 ]
