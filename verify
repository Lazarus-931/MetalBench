#!/usr/bin/env bash
# verify — reviewer-side. Reproduce a PR's claimed perf on your hardware.
#
# Usage:
#   ./verify 47                      # PR number on origin
#   ./verify user/MetalBench:branch  # explicit fork:branch
#
# Output is ONE LINE:
#   VERIFIED
#   ERROR: <one-line reason>
#
# Checks:
#   1. The PR body declares `Chip: <chip>` (e.g. m2, m4). If absent or
#      doesn't match this box's `sysctl machdep.cpu.brand_string`, ERROR.
#   2. For each changed `.metal` file in the PR: bench it, require
#      correctness ✓ AND the bench median within ±5% of the PR's
#      session.json best_time_ms for that (chip, kernel).
set -uo pipefail
cd "$(dirname "$0")"

err() { echo "ERROR: $1"; exit 1; }

[ $# -eq 1 ] || err "usage: ./verify <pr-number> | <fork:branch>"
TARGET="$1"
WORKTREE="/tmp/mb-verify-${TARGET//[\/:]/_}"
TOL=0.05

LOCAL_CHIP=$(sysctl -n machdep.cpu.brand_string 2>/dev/null | grep -oiE 'M[0-9]+' | head -1 | tr 'A-Z' 'a-z')
[ -n "$LOCAL_CHIP" ] || err "could not detect local M-chip via sysctl"

rm -rf "$WORKTREE"
if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
  command -v gh >/dev/null || err "needs gh CLI"
  PR_BODY=$(gh pr view "$TARGET" --json body --jq .body 2>/dev/null) || err "gh pr view $TARGET failed"
  gh pr checkout "$TARGET" --recurse-submodules=false >/dev/null 2>&1 || err "gh pr checkout failed"
  PR_BRANCH=$(git branch --show-current)
  git checkout main >/dev/null 2>&1
  git worktree add "$WORKTREE" "$PR_BRANCH" >/dev/null 2>&1 || err "git worktree add failed"
else
  fork="${TARGET%%:*}"; branch="${TARGET##*:}"
  git fetch "git@github.com:${fork}.git" "$branch:verify_${branch//\//_}" >/dev/null 2>&1 \
    || err "fetch fork:branch failed"
  git worktree add "$WORKTREE" "verify_${branch//\//_}" >/dev/null 2>&1 \
    || err "git worktree add failed"
  PR_BODY=""
fi

PR_CHIP=$(echo "$PR_BODY" | grep -oiE '^Chip:[[:space:]]*M[0-9]+' | head -1 | grep -oiE 'M[0-9]+' | tr 'A-Z' 'a-z')
if [ -n "$PR_CHIP" ] && [ "$PR_CHIP" != "$LOCAL_CHIP" ]; then
  err "chip mismatch (PR claims $PR_CHIP, this box is $LOCAL_CHIP)"
fi

cd "$WORKTREE"
CHANGED=$(git diff --name-only main -- 'metal/kernels/**/*.metal' 2>/dev/null)
[ -n "$CHANGED" ] || { cd - >/dev/null; echo "VERIFIED"; exit 0; }

KERNELS=()
for f in $CHANGED; do
  base=$(basename "$f" .metal)
  parent=$(basename "$(dirname "$f")")
  if [ "$parent" = "common" ] || [ "$parent" = "standard" ] || [ "$parent" = "full" ]; then
    KERNELS+=("$base")
  else
    KERNELS+=("$parent")
  fi
done
KERNELS=($(printf '%s\n' "${KERNELS[@]}" | awk '!seen[$0]++'))

for k in "${KERNELS[@]}"; do
  CLAIMED=$(python3 -c "
import json
try:
    s = json.load(open('session.json'))
    e = s.get('apple-${LOCAL_CHIP}', {}).get('${k}', {})
    print(e.get('best_time_ms', ''))
except Exception:
    print('')
" 2>/dev/null)
  [ -n "$CLAIMED" ] || err "no session.json record for $k on apple-${LOCAL_CHIP}"

  OUT=$(./bench "$k" --no-save -- --iters 100 --warmup 30 2>&1) || err "error benching $k"
  echo "$OUT" | grep -qE 'correctness\s+:\s*✓' || err "$k correctness failed"
  MEASURED=$(echo "$OUT" | grep -oE 'kernel[[:space:]]+:[[:space:]]*[0-9.e+-]+' | grep -oE '[0-9.e+-]+$' | head -1)
  [ -n "$MEASURED" ] || err "$k could not parse bench time"

  DIFF_PCT=$(python3 -c "print(f'{abs(${MEASURED}-${CLAIMED})/${CLAIMED}*100:.1f}')")
  python3 -c "import sys; sys.exit(0 if abs(${MEASURED}-${CLAIMED})/${CLAIMED} <= ${TOL} else 1)" \
    || err "perf not accurate, diff: ${DIFF_PCT}%"
done

cd - >/dev/null
echo "VERIFIED"
